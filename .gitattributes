########################################################
# Normalize line endings
########################################################

* text=auto

########################################################
# C#
########################################################

*.cs          text diff=csharp
*.csproj      text
*.sln         text

########################################################
# Razor
########################################################

*.razor       text
*.razor.css   text

########################################################
# Web
########################################################

*.css         text
*.js          text
*.html        text
*.htm         text

########################################################
# Config
########################################################

*.json        text
*.xml         text
*.config      text
*.editorconfig text
*.props       text
*.targets     text

########################################################
# Markdown
########################################################

*.md          text

########################################################
# Scripts
########################################################

*.ps1         text
*.cmd         text
*.bat         text
*.sh          text eol=lf

########################################################
# SQL
########################################################

*.sql         text

########################################################
# Images
########################################################

*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.svg         text

########################################################
# Fonts
########################################################

*.woff        binary
*.woff2       binary
*.ttf         binary
*.eot         binary

########################################################
# Archives
########################################################

*.zip         binary
*.rar         binary
*.7z          binary

########################################################
# PDFs
########################################################

*.pdf         binary

########################################################
# Excel / Word
########################################################

*.xlsx        binary
*.xls         binary
*.docx        binary

########################################################
# XML de NF-e
########################################################

*.xml         text