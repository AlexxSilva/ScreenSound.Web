<MudCard>
    <MudCardMedia Image="@($"data:image/jpeg;base64,{Artista!.FotoPerfil}")"
                  Height="250" />
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">@Artista!.Nome</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudText Typo="Typo.body2">@Artista!.Genero</MudText>
    </MudCardContent>
    <MudCardContent>
        <MudText Typo="Typo.body2">@Artista!.Bio</MudText>
    </MudCardContent>
    <MudCardActions>
        <MudButton Color="Color.Warning"
                   Variant="Variant.Outlined"
                   Href=@($"/EditarArtista/{Artista!.Nome}")>Detalhes</MudButton>
    </MudCardActions>
</MudCard>

@code {
    [Parameter]
    public ArtistaResponse? Artista { get; set; }

}